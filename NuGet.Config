<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet config for the bedtime-stories backend.
    All package references are public, so we resolve from nuget.org.
    <clear/> drops the inherited user-level private feed (nexus.diasteknoloji.com),
    which is unreachable outside that corporate network. Add it back here if an
    internal-only package is ever needed.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
