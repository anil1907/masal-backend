{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EncryptionKey": "ChangeMe-32CharsLong-AesEncrypKey",
  "TokenOptions": {
    "AccessTokenExpiration": 60,
    "RefreshTokenExpirationDays": 60,
    "Audience": "myapp@example.com",
    "Issuer": "myapp@example.com",
    "SecurityKey": "ChangeMe-AtLeast64CharsLongHmacSha512SigningKey!!!!!!!!!!!!!!!!!"
  },
  "StorySettings": {
    "DailyGenerationLimit": 10
  },
  "ConnectionString": "Host=localhost;Port=5434;Database=bedtime_stories;Username=postgres;Password=postgres;Timezone=UTC",
  "OtpSettings": {
    "CodeLength": 6,
    "ExpireMinutes": 5,
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5,
    "DailyLimit": 10
  },
  "SeriLogConfigurations": {
    "SeqLogConfiguration": {
      "Key": "",
      "Url": "http://localhost:5341",
      "Environment": "Development",
      "Application": "ApiTemplate"
    }
  },
  "FileStorage": {
    "UploadPath": "uploads"
  }
